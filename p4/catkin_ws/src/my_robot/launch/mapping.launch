<?xml version="1.0" encoding="UTF-8"?>

<launch>
  <arg name="database_path"     default="$(env HOME)/.ros/rtabmap.db"/>
  <arg name="rgb_topic"         default="/camera/rgb/image_raw"/>
  <arg name="depth_topic"       default="/camera/depth/image_raw"/>
  <arg name="camera_info_topic" default="/camera/rgb/camera_info"/>

  <group ns="rtabmap">
    <node name="rtabmap" pkg="rtabmap_slam" type="rtabmap" output="screen" args="--delete_db_on_start">

      <!-- ===================== CORE SETUP ===================== -->
      <param name="database_path"   type="string" value="$(arg database_path)"/>
      <param name="frame_id"        type="string" value="robot_footprint"/>
      <param name="odom_frame_id"   type="string" value="odom"/>

      <param name="subscribe_depth" type="bool"   value="true"/>
      <param name="subscribe_scan"  type="bool"   value="true"/>

      <!-- Topic remappings -->
      <remap from="scan"             to="/scan"/>
      <remap from="rgb/image"        to="$(arg rgb_topic)"/>
      <remap from="depth/image"      to="$(arg depth_topic)"/>
      <remap from="rgb/camera_info"  to="$(arg camera_info_topic)"/>
      <remap from="grid_map"         to="/map"/>

      <!-- ===================== RTABMAP TIMING ===================== -->
      <!-- Process a new node at most once per second to reduce drift -->
      <param name="Rtabmap/DetectionRate" type="string" value="1"/>

      <!-- ===================== REGISTRATION ===================== -->
      <!-- Force planar (2D) motion — critical for ground robots -->
      <param name="Reg/Force3DoF"  type="string" value="true"/>
      <!-- Use ICP (laser-based) for registration instead of visual-only.
           ICP is far more robust for 2D mapping with a lidar scan. -->
      <param name="Reg/Strategy"   type="string" value="1"/>  <!-- 0=Vis, 1=ICP, 2=Vis+ICP -->

      <!-- ===================== ODOMETRY ===================== -->
      <!-- Frame-to-Map: builds a local map and matches each new frame to it.
           More robust than F2F (value="1") in feature-poor or repetitive environments. -->
      <param name="Odom/Strategy"          type="string" value="0"/>
      <!-- No additional filtering on odometry (wheel odom assumed reliable) -->
      <param name="Odom/FilteringStrategy" type="string" value="0"/>

      <!-- ===================== ICP PARAMETERS ===================== -->
      <!-- Use libpointmatcher backend — more accurate than PCL for 2D scans -->
      <param name="Icp/Strategy"              type="string" value="1"/>
      <!-- Point-to-plane ICP: better surface matching, reduces map distortion -->
      <param name="Icp/PointToPlane"          type="string" value="true"/>
      <!-- Convergence epsilon for libpointmatcher — tighter = more precise -->
      <param name="Icp/PMMatcherEpsilon"      type="string" value="0.01"/>
      <!-- Voxel downsampling for speed and noise reduction -->
      <param name="Icp/VoxelSize"             type="string" value="0.05"/>
      <!-- Max ICP correspondence distance; increase slightly if scans are sparse -->
      <param name="Icp/MaxCorrespondenceDistance" type="string" value="0.1"/>
      <!-- Max ICP iterations; more iterations = more accurate but slower -->
      <param name="Icp/Iterations"            type="string" value="30"/>

      <!-- ===================== VISUAL FEATURES (fallback) ===================== -->
      <!-- SURF detector (used when visual reg is active or as loop closure aid) -->
      <param name="Kp/DetectorStrategy"  type="string" value="0"/>   <!-- 0=SURF -->
      <param name="Kp/MaxFeatures"       type="string" value="400"/>
      <param name="SURF/HessianThreshold" type="string" value="100"/>
      <!-- Raise min inliers threshold to reject weak visual matches -->
      <param name="Vis/MinInliers"       type="string" value="15"/>

      <!-- ===================== GRAPH / LOOP CLOSURE ===================== -->
      <!-- Refine links with ICP/laser after loop closure detection -->
      <param name="RGBD/NeighborLinkRefining"    type="string" value="true"/>
      <!-- Enable proximity detection by space (helps close loops in adjacent areas) -->
      <param name="RGBD/ProximityBySpace"        type="string" value="true"/>
      <!-- How many spatial neighbors to check during proximity detection -->
      <param name="RGBD/ProximityPathMaxNeighbors" type="string" value="10"/>
      <!-- Minimum robot movement (meters) before creating a new node — reduces redundancy -->
      <param name="RGBD/LinearUpdate"            type="string" value="0.1"/>
      <!-- Minimum rotation (radians) before creating a new node -->
      <param name="RGBD/AngularUpdate"           type="string" value="0.1"/>
      <!-- Optimize graph from the first node (not the last) — more globally consistent -->
      <param name="RGBD/OptimizeFromGraphEnd"    type="string" value="false"/>

      <!-- ===================== OCCUPANCY GRID ===================== -->
      <!-- Build occupancy grid from laser scan (not depth camera) — more accurate for 2D -->
      <param name="Grid/Sensor"          type="string" value="0"/>  <!-- 0=laser scan -->
      <!-- Cell size of occupancy grid in meters -->
      <param name="Grid/CellSize"        type="string" value="0.05"/>

      <!-- ===================== MEMORY ===================== -->
      <!-- Drop unlinked nodes to save memory; set true if you need full map reuse -->
      <param name="Mem/NotLinkedNodesKept" type="string" value="false"/>

    </node>
  </group>
</launch>
